{
  "swagger": "2.0",
  "info": {
    "title": "FadeBooker API",
    "description": "Sistema de gestión de citas para barberías - Marketplace de barbería. **Autenticación:** Use el header Authorization con el valor Bearer <token>. **Docs Visuales:** https://fadebooker-backend-ok.azurewebsites.net/api-docs",
    "version": "1.11.0"
  },
  "host": "fadebooker-backend-ok.azurewebsites.net",
  "basePath": "/api",
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Ingrese el token JWT con el prefijo Bearer. Ejemplo: 'Bearer <token>'"
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Verificar estado de la API",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "API operativa",
            "schema": {
              "type": "object",
              "properties": {
                "status": { "type": "string" },
                "timestamp": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/usuarios/register": {
      "post": {
        "summary": "Registrar nuevo usuario",
        "operationId": "registerUser",
        "tags": [ "Usuarios" ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { 
              "$ref": "#/definitions/UsuarioRegistro",
              "x-ms-summary": "Datos del Usuario",
              "example": {
                "email": "nuevo_cliente@example.com",
                "contrasena": "Password123!",
                "nombre": "Juan",
                "apellido": "Pérez",
                "telefono": "+56912345678",
                "rol": "Cliente"
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente",
            "schema": { "$ref": "#/definitions/Usuario" }
          },
          "400": { "description": "Email ya registrado o datos inválidos" }
        }
      }
    },
    "/usuarios/login": {
      "post": {
        "summary": "Autenticar usuario",
        "description": "Permite el ingreso al sistema validando credenciales y retornando un token JWT.",
        "operationId": "loginUser",
        "tags": [ "Usuarios" ],
        "security": [],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { 
              "$ref": "#/definitions/LoginRequest",
              "example": {
                "email": "admin@fadebooker.com",
                "contrasena": "Admin2026!"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login exitoso",
            "schema": { "$ref": "#/definitions/LoginResponse" }
          },
          "401": { "description": "Credenciales inválidas" }
        }
      }
    },
    "/usuarios/perfil": {
      "get": {
        "summary": "Obtener perfil del usuario autenticado",
        "description": "Retorna los datos del perfil del usuario actualmente autenticado mediante el token JWT.",
        "operationId": "getUserProfile",
        "tags": [ "Usuarios" ],
        "responses": {
          "200": {
            "description": "Perfil del usuario",
            "schema": { "$ref": "#/definitions/Usuario" }
          }
        }
      },
      "put": {
        "summary": "Actualizar perfil del usuario autenticado",
        "description": "Permite al usuario autenticado modificar sus datos personales (nombre, apellido, teléfono, email, contraseña).",
        "operationId": "updateUserProfile",
        "tags": [ "Usuarios" ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UsuarioUpdate" }
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil actualizado",
            "schema": { "$ref": "#/definitions/Usuario" }
          }
        }
      }
    },
    "/clientes": {
      "get": {
        "summary": "Listar todos los clientes",
        "operationId": "getClientes",
        "tags": [ "Clientes" ],
        "responses": {
          "200": {
            "description": "Lista de clientes",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Cliente" } }
