          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { 
              "$ref": "#/definitions/ClienteInput",
              "example": {
                "id_usuario": 10,
                "nombre": "Carlos",
                "apellido": "García",
                "email": "carlos.g@example.com",
                "telefono": "987654321"
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Cliente creado" },
          "400": { "description": "Datos inválidos" }
        }
      }
    },
    "/clientes/buscar": {
      "get": {
        "summary": "Buscar clientes por nombre",
        "operationId": "searchClientes",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "nombre", "in": "query", "required": true, "type": "string" }
        ],
        "responses": {
          "200": {
            "description": "Resultados de búsqueda",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Cliente" } }
          }
        }
      }
    },
    "/clientes/telefono/{telefono}": {
      "get": {
        "summary": "Buscar cliente por teléfono",
        "operationId": "getClienteByTelefono",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "telefono", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { 
            "description": "Cliente encontrado",
            "schema": { "$ref": "#/definitions/Cliente" } 
          },
          "404": { "description": "No encontrado" }
        }
      }
    },
    "/clientes/email/{email}": {
      "get": {
        "summary": "Obtener cliente por email",
        "operationId": "getClienteByEmail",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "email", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { 
            "description": "Cliente encontrado",
            "schema": { "$ref": "#/definitions/Cliente" } 
          },
          "404": { "description": "No encontrado" }
        }
      }
    },
    "/clientes/{id}": {
      "get": {
        "summary": "Obtener cliente por ID",
        "operationId": "getClienteById",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { 
            "description": "Detalles del cliente",
            "schema": { "$ref": "#/definitions/Cliente" } 
          },
          "404": { "description": "No encontrado" }
        }
      },
      "put": {
        "summary": "Actualizar cliente",
        "operationId": "updateCliente",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/ClienteUpdate" } }
        ],
        "responses": {
          "200": { "description": "Actualizado" }
        }
      },
      "delete": {
        "summary": "Eliminar cliente",
        "operationId": "deleteCliente",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { "description": "Eliminado" }
        }
      }
    },
    "/clientes/{id}/puntos": {
      "put": {
        "summary": "Actualizar puntos de fidelidad",
        "operationId": "updateClientePuntos",
        "tags": [ "Clientes" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": { "puntos": { "type": "integer" } }
            }
          }
        ],
        "responses": {
          "200": { "description": "Puntos actualizados" }
        }
      }
    },
    "/barberos": {
      "get": {
        "summary": "Obtener todos los barberos",
        "operationId": "getBarberos",
        "tags": [ "Barberos" ],
        "responses": {
          "200": {
            "description": "Lista de barberos",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Barbero" } }
          }
        }
      },
      "post": {
        "summary": "Crear un nuevo barbero",
        "operationId": "createBarbero",
        "tags": [ "Barberos" ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { 
              "$ref": "#/definitions/BarberoInput",
              "example": {
                "id_usuario": 5,
                "id_tienda": 1,
                "nombre": "Marcos",
                "apellido": "Trim",
                "email": "marcos.barber@example.com",
                "telefono": "5551234",
                "especialidad": "Degradados y Barba",
                "anos_experiencia": 4,
                "tarifa_base": 15000
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Barbero creado" }
        }
      }
    },
    "/barberos/especialidad/{especialidad}": {
      "get": {
        "summary": "Buscar barberos por especialidad",
        "operationId": "getBarberosByEspecialidad",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "especialidad", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { 
            "description": "Lista de barberos filtrada",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Barbero" } } 
          }
        }
      }
    },
    "/barberos/email/{email}": {
      "get": {
        "summary": "Obtener barbero por email",
        "operationId": "getBarberoByEmail",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "email", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { 
            "description": "Barbero encontrado",
            "schema": { "$ref": "#/definitions/Barbero" } 
          },
          "404": { "description": "No encontrado" }
        }
      }
    },
    "/barberos/{id}": {
      "get": {
        "summary": "Obtener detalles del barbero",
        "operationId": "getBarberoById",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { 
            "description": "Detalles del barbero",
            "schema": { "$ref": "#/definitions/Barbero" } 
          }
        }
      },
      "put": {
        "summary": "Actualizar barbero",
        "operationId": "updateBarbero",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/BarberoUpdate" } }
        ],
        "responses": {
          "200": { "description": "Actualizado" }
        }
      },
      "delete": {
        "summary": "Eliminar barbero",
        "operationId": "deleteBarbero",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { "description": "Eliminado" }
        }
      }
    },
    "/barberos/{id}/servicios": {
      "get": {
        "summary": "Listar servicios de un barbero",
        "operationId": "getBarberoServicios",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": {
            "description": "Lista de servicios ofrecidos",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/ServicioBarbero" } }
          }
        }
      }
    },
    "/barberos/{id}/horario": {
      "put": {
        "summary": "Actualizar horario de atención",
        "operationId": "updateBarberoHorario",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/HorarioBarbero" } }
        ],
        "responses": {
          "200": { "description": "Horario actualizado" }
        }
      }
    },
    "/barberos/{id}/disponibilidad/{fecha}": {
      "get": {
        "summary": "Consultar disponibilidad en fecha específica",
        "operationId": "getBarberoDisponibilidad",
        "tags": [ "Barberos" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          { "name": "fecha", "in": "path", "required": true, "type": "string", "format": "date" }
        ],
        "responses": {
          "200": {
            "description": "Horarios libres",
            "schema": {
              "type": "object",
              "properties": {
                "id_barbero": { "type": "integer" },
                "fecha": { "type": "string" },
                "disponibilidad": { "type": "array", "items": { "type": "object" } }
              }
            }
          }
        }
      }
    },
    "/servicios": {
      "get": {
        "summary": "Obtener catálogo de servicios base",
        "operationId": "getServicios",
        "tags": [ "Servicios" ],
        "responses": {
          "200": {
            "description": "Lista de servicios base",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Servicio" } }
          }
        }
      },
      "post": {
        "summary": "Crear nuevo servicio base",
        "operationId": "createServicio",
        "tags": [ "Servicios" ],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/ServicioInput" } }
        ],
        "responses": {
          "201": { "description": "Servicio creado" }
        }
      }
    },
    "/servicios/buscar": {
      "get": {
        "summary": "Buscar servicios por nombre",
        "operationId": "searchServicios",
        "tags": [ "Servicios" ],
        "parameters": [
          { "name": "nombre", "in": "query", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { 
            "description": "Servicios encontrados",
            "schema": { "type": "array", "items": { "$ref": "#/definitions/Servicio" } } 
          }
        }
      }
    },
    "/servicios/{id}": {
      "get": {
        "summary": "Obtener detalles del servicio",
        "operationId": "getServicioById",
        "tags": [ "Servicios" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { 
            "description": "Detalles del servicio",
            "schema": { "$ref": "#/definitions/Servicio" } 
          }
        }
      },
      "put": {
        "summary": "Actualizar servicio",
        "operationId": "updateServicio",
        "tags": [ "Servicios" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/ServicioUpdate" } }
        ],
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": {
        "summary": "Eliminar servicio",
        "operationId": "deleteServicio",
        "tags": [ "Servicios" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": { "200": { "description": "Eliminado" } }
      }
    },
    "/citas": {
      "post": {
        "summary": "Agendar nueva cita",
        "operationId": "createCita",
        "tags": [ "Citas" ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { 
              "$ref": "#/definitions/CitaInput",
              "example": {
                "id_cliente": 1,
                "id_barbero": 2,
                "id_servicio": 1,
                "fecha_hora_inicio": "2026-05-20T15:00:00Z",
                "pago_abono": 5000,
                "metodo_pago": "Transferecia",
                "notas": "Corte degradado con barba"
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Cita agendada", "schema": { "$ref": "#/definitions/CitaResponse" } },
          "400": { "description": "Conflicto de horario o datos inválidos" }
        }
      }
    },
    "/citas/{id}": {
      "get": {
        "summary": "Obtener detalles de una cita",
        "description": "Retorna la información completa de una cita específica identificada por su ID.",
        "operationId": "getCitaById",
        "tags": [ "Citas" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": {
            "description": "Detalles de la cita",
            "schema": { "$ref": "#/definitions/CitaResponse" }
          },
          "404": { "description": "No encontrada" }
        }
      },
      "delete": {
        "summary": "Eliminar/Cancelar cita físicamente",
        "description": "Elimina de forma permanente el registro de una cita del sistema.",
        "operationId": "deleteCita",
        "tags": [ "Citas" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { "description": "Eliminada" }
        }
      }
    },
    "/citas/{id}/estado": {
      "put": {
        "summary": "Cambiar estado de la cita",
        "operationId": "updateCitaEstado",
        "tags": [ "Citas" ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "estado": { "type": "string", "enum": ["confirmada", "cancelada", "completada", "no_presentado"] }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Estado actualizado" }
        }
      }
    },
    "/hairstyle/signature": {
      "post": {
        "summary": "Generar firma para Cloudinary",
        "operationId": "getCloudinarySignature",
        "tags": [ "Hairstyle" ],
        "responses": {
          "200": {
            "description": "Firma generada",
            "schema": {
              "type": "object",
              "properties": {
                "signature": { "type": "string" },
                "timestamp": { "type": "integer" },
                "apiKey": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/hairstyle/simulate": {
      "post": {
        "summary": "Simular corte de pelo",
        "operationId": "simulateHairstyle",
        "tags": [ "Hairstyle" ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "publicId": { "type": "string" },
                "styleId": { "type": "string", "enum": ["degradado", "clasico", "moderno", "mohicano", "buzzcut"] }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Simulación exitosa",
            "schema": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean" },
                "simulatedImageUrl": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/reportes/citas": {
      "get": {
        "summary": "Generar reporte de citas (Excel)",
        "operationId": "getReporteCitas",
        "tags": [ "Reportes" ],
        "parameters": [
          { "name": "fechaInicio", "in": "query", "type": "string", "format": "date" },
          { "name": "fechaFin", "in": "query", "type": "string", "format": "date" }
        ],
        "responses": {
          "200": {
            "description": "Reporte generado",
            "schema": { "type": "string", "format": "binary" }
          }
        }
      }
    }
  },
  "definitions": {
    "Usuario": {
      "type": "object",
      "x-ms-summary": "Usuario",
      "description": "Entidad base de usuario del sistema",
      "properties": {
        "id_usuario": { "type": "integer" },
        "email": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "rol": { "type": "string" },
        "estado": { "type": "boolean" }
      },
      "example": {
        "id_usuario": 1,
        "email": "admin@fadebooker.com",
        "nombre": "Admin",
        "apellido": "Sistema",
        "rol": "Administrador",
        "estado": true
      }
    },
    "UsuarioRegistro": {
      "type": "object",
      "required": [ "email", "contrasena", "nombre", "apellido", "rol" ],
      "x-ms-summary": "Registro de Usuario",
      "description": "Datos necesarios para registrar un nuevo usuario",
      "properties": {
        "email": { "type": "string" },
        "contrasena": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "telefono": { "type": "string" },
        "rol": { "type": "string", "enum": [ "Cliente", "Barbero", "Dueño", "Administrador" ] }
      },
      "example": {
        "email": "nuevo_cliente@example.com",
        "contrasena": "Password123!",
        "nombre": "Juan",
        "apellido": "Pérez",
        "telefono": "+56912345678",
        "rol": "Cliente"
      }
    },
    "UsuarioUpdate": {
      "type": "object",
      "x-ms-summary": "Actualización de Perfil",
      "description": "Campos permitidos para actualizar el perfil del usuario",
      "properties": {
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "telefono": { "type": "string" },
        "email": { "type": "string" },
        "contrasena": { "type": "string" }
      },
      "example": {
        "nombre": "Juan",
