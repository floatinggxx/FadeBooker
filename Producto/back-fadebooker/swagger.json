      "get": {
        "summary": "Verificar estado de la API",
        "responses": {
          "200": {
            "description": "API operativa",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok",
                  "timestamp": "2026-04-29T10:30:00Z",
                  "message": "FadeBooker API is running"
                }
              }
            }
          }
        }
      }
    },
