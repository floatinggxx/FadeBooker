{
  "openapi": "3.0.0",
  "info": {
    "title": "FadeBooker API",
    "description": "Sistema de gesti\u00f3n de citas para barber\u00edas - Marketplace de barber\u00eda. \n\n**Autenticaci\u00f3n:** Use el header Authorization con el valor Bearer <token>.",
    "version": "1.11.0"
  },
  "servers": [
    {
      "url": "https://fadebooker-backend-ok.azurewebsites.net/api",
      "description": "Production server (Azure)"
    },
    {
      "url": "http://localhost:3000/api",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Usuarios",
      "description": "Gesti\u00f3n de cuentas y autenticaci\u00f3n"
    },
    {
      "name": "Clientes",
      "description": "Operaciones CRUD para clientes"
    },
    {
      "name": "Barberos",
      "description": "Gesti\u00f3n de barberos y su disponibilidad"
    },
    {
      "name": "Servicios",
      "description": "Cat\u00e1logo base de servicios"
    },
    {
      "name": "Citas",
      "description": "Agendamiento y control de estados"
    },
    {
      "name": "Hairstyle",
      "description": "Simulaci\u00f3n de cortes y gesti\u00f3n de im\u00e1genes"
    },
    {
      "name": "Reportes",
      "description": "Generaci\u00f3n de reportes administrativos"
    }
  ],
